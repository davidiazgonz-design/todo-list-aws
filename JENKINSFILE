pipeline {
    agent any

    stages {
        stage('Get Code') {
            steps {
                git url: 'https://github.com/davidiazgonz-design/todo-list-aws.git', branch: 'develop'
            }
        }

        stage('Static Test') {
            steps {
                sh '''
                    python3 -m venv venv
                    . venv/bin/activate
                    pip install --upgrade pip flake8 bandit
                    mkdir -p target
                    flake8 . --exclude=venv --format=pylint > target/flake8.out || true
                    bandit -r . -x ./venv -f custom --msg-template "{relpath}:{line}:{test_id}:{msg}" -o target/bandit.out || true
                '''
                recordIssues tool: flake8(pattern: '**/target/flake8.out')
                recordIssues tool: pyLint(pattern: '**/target/bandit.out', id: 'bandit', name: 'Bandit Security Scan')
            }
        }

        stage('SAM Build') {
            steps {
                echo 'Compilando la aplicación Serverless con AWS SAM...'
                sh 'sam build'
            }
        }

        stage('SAM Deploy') {
            steps {
                echo 'Desplegando la infraestructura en AWS...'
                sh '''
                    sam deploy --stack-name todo-list-aws-stack \
                               --s3-bucket pruebaunir-p26 \
                               --capabilities CAPABILITY_IAM \
                               --no-confirm-changeset \
                               --no-fail-on-empty-changeset
                '''
            }
        }

        stage('Rest Test') {
            steps {
                echo '=== Iniciando Pruebas de Integración Dinámicas con Pytest ==='
                withCredentials([string(
                    credentialsId: 'aws-credenciales-proyecto', 
                    variable: 'AWS_SECRET_ACCESS_KEY'
                )]) {
                    sh '''
                        . venv/bin/activate
                        pip install pytest requests
                        BASE_URL=$(aws cloudformation describe-stacks \
                            --stack-name todo-list-aws-stack \
                            --region us-east-1 \
                            --query 'Stacks[0].Outputs[?OutputKey==`BaseUrlApi`].OutputValue' \
                            --output text)
                        echo "URL de producción detectada: ${BASE_URL}"
                        export BASE_URL
                        pytest test/integration/todoApiTest.py
                    '''
                }
            }
        }

        stage('Promote') {
            steps {
                echo '=== Promocionando a Master de forma segura (Merge Develop -> Master) ==='
                withCredentials([usernamePassword(
                    credentialsId: 'github-token-escritura', 
                    usernameVariable: 'GIT_USER', 
                    passwordVariable: 'GIT_PASSWORD'
                )]) {
                    sh '''
                        git config user.name "Jenkins CI"
                        git config user.email "jenkins@ci.com"
                        git fetch origin
                        git checkout master || git checkout -b master origin/master
                        git pull origin master
                        git merge origin/develop --no-edit
                        git remote set-url origin https://${GIT_USER}:${GIT_PASSWORD}@github.com/davidiazgonz-design/todo-list-aws.git
                        git push origin master
                        echo "=== ¡Promoción completada y código mergeado con éxito! ==="
                    '''
                }
            }
        }
    }
}
